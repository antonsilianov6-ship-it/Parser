# Web-panel runtime env. Copy to `.env` and edit before `docker compose up`.

# Required: long random string used to sign JWTs.
# Generate with: openssl rand -hex 32
PANEL_JWT_SECRET=replace-me-with-32-random-bytes

# Optional overrides
PANEL_JWT_ALGORITHM=HS256
PANEL_JWT_ACCESS_TTL_MINUTES=720
PANEL_PORT=8000
