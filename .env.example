# Web-panel runtime env. Copy to `.env` and edit before `docker compose up`.

# Required: long random string used to sign JWTs.
# Generate with: openssl rand -hex 32
PANEL_JWT_SECRET=replace-me-with-32-random-bytes

# Optional overrides
PANEL_JWT_ALGORITHM=HS256
PANEL_JWT_ACCESS_TTL_MINUTES=720
PANEL_PORT=8000

# Headed Chromium service ("browser") — used for noVNC-driven NotebookLM logins.
# Leave the CDP url at the default so the panel container reaches the
# browser container over the docker network. Set the public url to your
# server's hostname/IP (the SPA loads it as an <iframe src=...>); on
# localhost the default is fine.
BROWSER_NOVNC_PORT=6080
PANEL_BROWSER_CDP_URL=http://browser:9222
PANEL_BROWSER_PUBLIC_URL=http://localhost:6080
